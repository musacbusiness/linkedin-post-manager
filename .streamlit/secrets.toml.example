# Streamlit Secrets Configuration
# Copy this file to .streamlit/secrets.toml and fill in your actual values
# On Streamlit Cloud, set these via App Settings > Secrets

# Required: Anthropic API (for Claude)
ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxx"

# Required: Supabase
SUPABASE_URL = "https://xxxxxxxxxxxx.supabase.co"
SUPABASE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Optional: HuggingFace (for some model integrations)
HUGGINGFACE_TOKEN = "hf_xxxxxxxxxxxx"

# Optional: Replicate (for image generation)
REPLICATE_API_TOKEN = "r8_xxxxxxxxxxxx"

# Optional: User preferences
USER_EXPERTISE = "AI automation consultant"
USER_TARGET_AUDIENCE = "small business owners, solopreneurs"
USER_TONE = "practical, approachable, authentic"
USER_AVOID = "jargon, corporate speak, hype"
